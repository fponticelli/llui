{
  "name": "llui",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "pnpm --filter @llui/mcp test",
    "smoke:examples": "tsx scripts/smoke-examples.ts",
    "check:docs": "node scripts/check-readme-examples.mjs",
    "verify": "pnpm format && turbo run build check lint test && pnpm check:docs",
    "bench": "tsx benchmarks/run-jfb.ts",
    "bench:build": "pnpm --filter js-framework-benchmark-keyed-llui build-prod",
    "bench:setup": "git clone https://github.com/krausest/js-framework-benchmark.git benchmarks/js-framework-benchmark-repo 2>/dev/null || true && cd benchmarks/js-framework-benchmark-repo && npm ci && cd server && npm ci && cd ../webdriver-ts && npm ci && npm run compile",
    "bench:ticker:setup": "tsx scripts/setup-ticker.ts",
    "bench:ticker": "tsx scripts/run-ticker.ts",
    "bench:all": "tsx scripts/run-bench-all.ts",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,jsx,json,md,css,html,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/runner": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.2.5",
    "magic-string": "^0.30.21",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
