{
  "name": "llui",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "verify": "pnpm format && turbo run build check lint test",
    "bench": "tsx benchmarks/run-jfb.ts",
    "bench:build": "pnpm --filter js-framework-benchmark-keyed-llui build-prod",
    "bench:setup": "git clone https://github.com/krausest/js-framework-benchmark.git benchmarks/js-framework-benchmark-repo 2>/dev/null || true && cd benchmarks/js-framework-benchmark-repo && npm ci && cd webdriver-ts && npm ci && npm run compile"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/runner": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "magic-string": "^0.30.21",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
