{
  "name": "llui",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "bench": "vitest run --config benchmarks/vitest.config.ts --reporter=verbose",
    "bench:browser": "tsx benchmarks/runtime-browser.ts",
    "bench:browser:save": "tsx benchmarks/runtime-browser.ts --save",
    "bench:compare": "tsx benchmarks/comparison/run.ts",
    "bench:size": "node benchmarks/bundle-size.js",
    "bench:size:save": "node benchmarks/bundle-size.js --save"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/runner": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "magic-string": "^0.30.21",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "solid-js": "^1.9.12",
    "svelte": "^5.55.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^4.1.2"
  }
}
