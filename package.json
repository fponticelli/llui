{
  "name": "llui",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test",
    "bench": "vitest run --config benchmarks/vitest.config.ts --reporter=verbose",
    "bench:size": "node benchmarks/bundle-size.js",
    "bench:size:save": "node benchmarks/bundle-size.js --save"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/runner": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
