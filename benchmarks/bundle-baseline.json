      "perfImpact": {
        "swap1to998": "+89%",
        "select1k": "+87%",
        "remove": "+37%",
        "update10th": "+23%",
        "createReplaceAppend": "within noise"
      }
    },
    "2.1": {
      "label": "Tier 2.1 variable-length binding tuples",
      "summary": "Compiler emits 2/3/4/5-tuple binding shapes for elSplit and a 3-arg short form for __bind; runtime dispatches on tuple.length / typeof. CORRECT but unprofitable for jfb because the bench routes nearly all bindings through elTemplate (row factory) and only has a handful of elSplit/__bind sites — the dispatch-overhead bytes exceed the per-call savings here. Reverted; would help apps with many flat elSplit bindings outside the elTemplate row path.",
      "measuredUncompressed": 38049,
