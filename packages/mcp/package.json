{
  "name": "@llui/mcp",
  "version": "0.0.26",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "llui-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@llui/eslint-plugin": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@llui/dom": "^0.0.31",
    "playwright": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@llui/dom": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "playwright": "*"
  },
  "description": "LLui MCP server — LLM debug tools via Model Context Protocol",
  "keywords": [
    "llui",
    "mcp",
    "debug",
    "llm",
    "devtools"
  ],
  "author": "Franco Ponticelli <franco.ponticelli@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fponticelli/llui.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/fponticelli/llui/issues"
  },
  "homepage": "https://github.com/fponticelli/llui/tree/main/packages/mcp#readme"
