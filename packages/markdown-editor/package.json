{
  "name": "@llui/markdown-editor",
  "version": "0.4.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugins/core": {
      "types": "./dist/plugins/core.d.ts",
      "import": "./dist/plugins/core.js"
    },
    "./plugins/callout": {
      "types": "./dist/plugins/callout.d.ts",
      "import": "./dist/plugins/callout.js"
    },
    "./surfaces/toolbar": {
      "types": "./dist/surfaces/toolbar.d.ts",
      "import": "./dist/surfaces/toolbar.js"
    },
    "./plugins/block-drag": {
      "types": "./dist/plugins/block-drag.d.ts",
      "import": "./dist/plugins/block-drag.js"
    },
    "./plugins/code-language": {
      "types": "./dist/plugins/code-language.d.ts",
      "import": "./dist/plugins/code-language.js"
    },
    "./plugins/wikilink": {
      "types": "./dist/plugins/wikilink.d.ts",
      "import": "./dist/plugins/wikilink.js"
    },
    "./styles/editor.css": "./dist/styles/editor.css",
    "./styles/block-drag.css": "./dist/styles/block-drag.css"
  },
  "scripts": {
    "prepack": "pnpm run build",
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/styles && cp src/styles/*.css dist/styles/",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@llui/dom": "workspace:^",
    "@llui/lexical": "workspace:^",
    "@llui/components": "workspace:^",
    "@llui/markdown": "workspace:^",
    "lexical": "^0.48.0",
    "@lexical/markdown": "^0.48.0",
    "@lexical/rich-text": "^0.48.0",
    "@lexical/list": "^0.48.0",
    "@lexical/link": "^0.48.0",
    "@lexical/table": "^0.48.0",
    "@lexical/selection": "^0.48.0",
    "@lexical/utils": "^0.48.0",
    "@lexical/code-core": "^0.48.0"
  },
  "devDependencies": {
    "@llui/dom": "workspace:*",
    "@llui/lexical": "workspace:*",
    "@llui/components": "workspace:*",
    "@llui/markdown": "workspace:*",
    "lexical": "^0.48.0",
    "@lexical/headless": "^0.48.0",
    "@lexical/markdown": "^0.48.0",
    "@lexical/rich-text": "^0.48.0",
    "@lexical/list": "^0.48.0",
    "@lexical/link": "^0.48.0",
    "@lexical/table": "^0.48.0",
    "@lexical/selection": "^0.48.0",
    "@lexical/utils": "^0.48.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.2",
    "@lexical/code-core": "^0.48.0"
  },
  "sideEffects": [
    "./dist/styles/editor.css",
    "./dist/styles/block-drag.css"
  ],
  "description": "WYSIWYG Markdown editor for LLui — hides Markdown behind a rich, pluggable editing widget built on Lexical",
  "keywords": [
    "llui",
    "markdown",
    "editor",
    "wysiwyg",
    "lexical",
    "rich-text"
  ],
  "author": "Franco Ponticelli <franco.ponticelli@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fponticelli/llui.git",
    "directory": "packages/markdown-editor"
  },
  "bugs": {
    "url": "https://github.com/fponticelli/llui/issues"
  },
  "homepage": "https://github.com/fponticelli/llui/tree/main/packages/markdown-editor#readme",
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  }
}
