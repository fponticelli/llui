{
  "name": "@llui/test",
  "version": "0.11.7",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "prepack": "pnpm run build",
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@llui/dom": "^0.11.5"
  },
  "devDependencies": {
    "@llui/agent": "workspace:*",
    "@llui/dom": "workspace:*"
  },
  "description": "LLui test harness — testComponent, testView, propertyTest, replayTrace, assertEffects",
  "keywords": [
    "llui",
    "test",
    "testing",
    "harness",
    "property-test"
  ],
  "author": "Franco Ponticelli <franco.ponticelli@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fponticelli/llui.git",
    "directory": "packages/test"
  },
  "bugs": {
    "url": "https://github.com/fponticelli/llui/issues"
  },
  "homepage": "https://github.com/fponticelli/llui/tree/main/packages/test#readme",
  "publishConfig": {
    "access": "public"
  }
}
