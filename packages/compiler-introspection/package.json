{
  "name": "@llui/compiler-introspection",
  "version": "0.5.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@llui/compiler": "workspace:*",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  },
  "description": "LLui compiler — runtime introspection metadata (opt-in). Schema/annotation/hash emission consumed by @llui/agent-bridge (end-user agent) and @llui/mcp (dev MCP).",
  "keywords": [
    "llui",
    "compiler",
    "introspection",
    "schema"
