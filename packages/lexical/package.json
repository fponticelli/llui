{
  "name": "@llui/lexical",
  "version": "0.2.9",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prepack": "pnpm run build",
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@llui/dom": "^0.11.5",
    "lexical": "^0.46.0",
    "@lexical/history": "^0.46.0",
    "@lexical/rich-text": "^0.46.0",
    "@lexical/selection": "^0.46.0",
    "@lexical/utils": "^0.46.0"
  },
  "devDependencies": {
    "@llui/dom": "workspace:*",
    "lexical": "^0.46.0",
    "@lexical/headless": "^0.46.0",
    "@lexical/history": "^0.46.0",
    "@lexical/rich-text": "^0.46.0",
    "@lexical/selection": "^0.46.0",
    "@lexical/utils": "^0.46.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.2"
  },
  "sideEffects": false,
  "description": "Low-level binding between Lexical and the LLui signal runtime — mount Lexical via foreign(), plugin contract, and the DecoratorNode ↔ LLui sub-view bridge",
