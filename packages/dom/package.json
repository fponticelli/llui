{
  "name": "@llui/dom",
  "version": "0.11.6",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./devtools": {
      "types": "./dist/signals/devtools.d.ts",
      "import": "./dist/signals/devtools.js"
    },
    "./ssr": {
      "types": "./dist/ssr-dom.d.ts",
      "import": "./dist/ssr-dom.js"
    },
    "./ssr/jsdom": {
      "types": "./dist/ssr/jsdom.d.ts",
      "import": "./dist/ssr/jsdom.js"
    },
    "./ssr/linkedom": {
      "types": "./dist/ssr/linkedom.d.ts",
      "import": "./dist/ssr/linkedom.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    },
    "./escape-hatch": {
      "types": "./dist/signals/escape-hatch.d.ts",
      "import": "./dist/signals/escape-hatch.js"
    }
  },
  "peerDependencies": {
    "jsdom": "*",
    "linkedom": "*"
  },
  "peerDependenciesMeta": {
    "jsdom": {
      "optional": true
    },
    "linkedom": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "pnpm run build",
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "description": "LLui runtime — TEA component model, mount, scope tree, bindings, structural primitives, element helpers",
  "keywords": [
    "llui",
    "tea",
    "elm-architecture",
    "reactive",
    "dom",
    "framework",
    "compile-time",
    "bitmask"
  ],
  "author": "Franco Ponticelli <franco.ponticelli@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fponticelli/llui.git",
    "directory": "packages/dom"
  },
  "bugs": {
    "url": "https://github.com/fponticelli/llui/issues"
  },
  "homepage": "https://github.com/fponticelli/llui/tree/main/packages/dom#readme",
  "devDependencies": {
    "@llui/compiler": "workspace:*"
  }
}
