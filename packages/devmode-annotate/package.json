{
  "name": "@llui/devmode-annotate",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./note-types": {
      "types": "./dist/note-types.d.ts",
      "import": "./dist/note-types.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@llui/components": "workspace:*",
    "@llui/lexical": "workspace:*",
    "@llui/markdown-editor": "workspace:*",
    "html-to-image": "^1.11.13",
    "lexical": "^0.45.0",
    "@lexical/markdown": "^0.45.0",
    "@lexical/rich-text": "^0.45.0",
    "@lexical/list": "^0.45.0",
    "@lexical/link": "^0.45.0",
    "@lexical/table": "^0.45.0",
    "@lexical/selection": "^0.45.0",
    "@lexical/utils": "^0.45.0",
    "@lexical/code-core": "^0.45.0"
  },
  "peerDependencies": {
    "@llui/dom": "^0.9.0"
  },
  "devDependencies": {
    "@llui/dom": "workspace:*",
    "@llui/test": "workspace:*",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "description": "LLui dev-mode HUD — drop annotated notes from the running app into the shared notebook for the LLM to consume",
  "keywords": [
    "llui",
    "devtools",
    "annotation",
    "llm",
    "screenshot"
  ],
  "author": "Franco Ponticelli <franco.ponticelli@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fponticelli/llui.git",
    "directory": "packages/devmode-annotate"
  },
  "bugs": {
    "url": "https://github.com/fponticelli/llui/issues"
  },
  "homepage": "https://github.com/fponticelli/llui/tree/main/packages/devmode-annotate#readme"
}
